APP_ENV=local
APP_NAME=TopoAudit Benin
API_BASE_URL=http://localhost:8000/api
FRONTEND_URL=http://localhost:3000
DATABASE_URL=postgresql+psycopg://topoaudit:topoaudit@db:5432/topoaudit
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/data/uploads
OCR_PROVIDER=mock
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=
AZURE_DOCUMENT_INTELLIGENCE_API_VERSION=2024-11-30
AZURE_DOCUMENT_INTELLIGENCE_MODEL_ID=prebuilt-layout
GEMINI_API_KEY=
GEMINI_API_ENDPOINT=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemma-4-31b-it
# Mistral OCR 4 (provider OCR sélectionnable) — NE JAMAIS committer/logger MISTRAL_API_KEY.
MISTRAL_API_KEY=
MISTRAL_API_ENDPOINT=https://api.mistral.ai/v1
MISTRAL_OCR_MODEL=mistral-ocr-latest
MISTRAL_INCLUDE_BLOCKS=true
MISTRAL_CONFIDENCE_GRANULARITY=word
MAP_PROVIDER=esri_world_imagery
ESRI_WORLD_IMAGERY_URL=https://services.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer
GOOGLE_MAPS_API_KEY=
MAX_UPLOAD_MB=25
SECRET_KEY=change-me
# Sécurité SaaS (P1.1)
JWT_SECRET=dev-insecure-change-me
JWT_EXPIRES_SECONDS=86400
# Mode démo sans authentification — automatiquement DÉSACTIVÉ si APP_ENV=production.
DEMO_LOCAL=true
# Fond cartographique unique : Esri World Imagery (frontend MapLibre) — INDICATIF, non
# référence cadastrale. Valeur par défaut si non définie ; voir docs/external_services/map_tiles_policy.md.
NEXT_PUBLIC_SATELLITE_TILE_URL=https://services.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}
